# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============================
# Dependencies (all workspaces)
# ============================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================
# Next.js build artifacts
# ============================
.next/
frontend/.next/
out/
frontend/out/

# ============================
# Production builds
# ============================
build/
dist/

# ============================
# Environment variables — NEVER commit these
# ============================
.env
.env*.local
*.env

# ============================
# Debug logs
# ============================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ============================
# TypeScript
# ============================
*.tsbuildinfo
next-env.d.ts
frontend/next-env.d.ts

# ============================
# OS / Editor
# ============================
.DS_Store
*.pem
.vercel
.vscode/
